{
  "name": "opendocuments-server",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "opendocuments-core": "0.1.2"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "description": "HTTP/MCP server for OpenDocuments - self-hosted RAG platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joungminsung/OpenDocuments.git",
    "directory": "packages/server"
  },
  "keywords": [
    "rag",
    "mcp",
    "hono",
    "api-server"
  ],
  "files": [
    "dist/**/*"
  ]
}
